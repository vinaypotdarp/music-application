# Copy this file to ".env" in the same folder and fill in your keys.
# See ../SETUP.md for step-by-step instructions on getting each key.

# Google Maps Platform key (used for Routes API, Geocoding API, Places API,
# and the Weather API — all live under one Maps Platform key/project).
GOOGLE_MAPS_API_KEY=

# YouTube Data API v3 key (from Google Cloud Console, can be the same GCP
# project as Maps Platform, but is a separate API + separate key is cleanest).
YOUTUBE_API_KEY=

# Gemini API key — powers the actual generative "AI Brain" chat (server/src/
# routes/brain.js). Free, no billing account needed. Get one at
# https://aistudio.google.com/apikey. Without this, the chat still works but
# runs on the old rule-based regex/if-else logic instead of a real model.
GEMINI_API_KEY=

# Optional: override the Gemini model (defaults to gemini-3.5-flash).
GEMINI_MODEL=

# Port the backend listens on.
PORT=8787

# Optional: set to "true" to force mock data even if keys are present
# (useful for demoing without burning API quota).
FORCE_MOCK=false
